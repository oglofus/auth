{
  "name": "@oglofus/auth",
  "version": "1.1.3",
  "private": false,
  "description": "Type-safe, plugin-first authentication core",
  "homepage": "https://github.com/oglofus/auth#readme",
  "bugs": {
    "url": "https://github.com/oglofus/auth/issues"
  },
  "license": "ISC",
  "author": "Oglofus Ltd",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oglofus/auth.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "tsx --test test/**/*.test.ts",
    "prepublishOnly": "npm run build",
    "format": "vp fmt .",
    "prepare": "vp config"
  },
  "dependencies": {
    "@oslojs/otp": "^1.1.0",
    "arctic": "^3.7.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "stripe": "^20.4.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite-plus": "catalog:"
  },
  "peerDependencies": {
    "stripe": "^22.0.0"
  },
  "packageManager": "pnpm@10.33.0"
}
