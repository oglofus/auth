{
  "name": "@oglofus/auth",
  "version": "1.1.0",
  "description": "Type-safe, plugin-first authentication core",
  "homepage": "https://github.com/oglofus/auth#readme",
  "bugs": {
    "url": "https://github.com/oglofus/auth/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oglofus/auth.git"
  },
  "license": "ISC",
  "author": "Oglofus Ltd",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "tsx --test test/**/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
